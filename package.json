{
  "name": "@pbuilder/sdk",
  "version": "0.0.0",
  "description": "The public TypeScript/Bun authoring layer for Project Builder schematics. Authors file mutations (create, modify, remove, rename, move, copy, copyIn), lowers them to IR, and talks to the Project Builder engine over framed stdio (see docs/engine-sdk-wire-spec.md).",
  "license": "MIT",
  "type": "module",
  "private": false,
  "author": "Project Builder Schematics",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Project-Builder-Schematics/project-builder-sdk.git"
  },
  "homepage": "https://github.com/Project-Builder-Schematics/project-builder-sdk#readme",
  "bugs": {
    "url": "https://github.com/Project-Builder-Schematics/project-builder-sdk/issues"
  },
  "keywords": [
    "project-builder",
    "schematics",
    "code-generation",
    "scaffolding",
    "ast",
    "codemod"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=25.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "pbuilder-codegen": "dist/bin/pbuilder-codegen.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./commons": {
      "types": "./dist/commons/index.d.ts",
      "import": "./dist/commons/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance/index.d.ts",
      "import": "./dist/conformance/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./typescript": {
      "types": "./dist/dialects/typescript/index.d.ts",
      "import": "./dist/dialects/typescript/index.js"
    },
    "./react": {
      "types": "./dist/dialects/react/index.d.ts",
      "import": "./dist/dialects/react/index.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "typecheck:permissive-proof": "tsc --noEmit -p tsconfig.permissive-proof.json",
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && bun build bin/pbuilder-codegen.ts --outfile dist/bin/pbuilder-codegen.js --target node --banner \"#!/usr/bin/env node\"",
    "prepublishOnly": "bun run build",
    "publish:dry": "npm publish --dry-run",
    "link:sdk": "bun run build && bun link"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "expect-type": "^1.3.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "ts-morph": "28.0.0"
  }
}
